# Copy this file to .env and update the values before running the backend.
DATABASE_URL="postgresql://postgres:password@localhost:5432/supportme?schema=public"
# PORT=4000
JWT_SECRET="your-secret-key-here-change-in-production"
NODE_ENV="development"

# Soroban event listener (polls for on-chain donations and streams them to
# the frontend over SSE at /api/events). Without the contract ID set, the
# listener logs a warning and skips polling.
NEXT_PUBLIC_DONATION_CONTRACT_ID="CD6T563YCSYQHDMXC7VCFTKMWMXWHFHAU4NO7EAMFK57QLFI7SSXICYY"
# SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"
# SOROBAN_EVENTS_POLL_INTERVAL_MS=5000
# SOROBAN_EVENTS_LOOKBACK_LEDGERS=100
